# ── Base de données Neon (PostgreSQL) ─────────────────────────────────────────
# Récupère cette URL sur neon.tech → ton projet → Connection Details → Nodejs
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/thomas_portfolio?sslmode=require

# ── Authentification Admin ─────────────────────────────────────────────────────
# Génère un secret aléatoire sur : https://generate-secret.vercel.app/32
JWT_SECRET=remplace-par-une-chaine-aleatoire-de-32-caracteres

# Ton mot de passe admin hashé avec bcrypt
# Pour générer le hash, lance : node -e "require('bcryptjs').hash('TonMotDePasse',10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$REMPLACE_PAR_TON_HASH_BCRYPT

# ── Email SMTP ────────────────────────────────────────────────────────────────
# Si tu utilises Gmail : active "Mots de passe d'application" dans ton compte Google
# Si tu utilises Hostinger : mets tes identifiants email Hostinger
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ton.email@gmail.com
SMTP_PASS=mot-de-passe-application-gmail

# Email qui reçoit les messages du formulaire de contact
CONTACT_EMAIL=leloupthomas.pro@gmail.com

# ── URL du site ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
